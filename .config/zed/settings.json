// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
	"ssh_connections": [
		{
			"host": "ganesha.aoide.de",
			"args": [],
			"projects": [
				{
					"paths": ["/"],
				},
			],
		},
		{
			"host": "z-ganesha-bash",
			"args": [],
			"projects": [],
		},
	],
	"cli_default_open_behavior": "new_window",
	"project_panel": {
		"dock": "left",
	},
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"agent": {
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
	},
	"git_panel": {
		"dock": "left",
	},
	"inlay_hints": {
		"show_type_hints": false,
		"enabled": true,
	},
	"diff_view_style": "split",
	"show_signature_help_after_edits": true,
	"auto_signature_help": true,
	"active_pane_modifiers": {
		"border_size": 0.0,
		"inactive_opacity": 0.4,
	},
	"tabs": {
		"file_icons": true,
	},
	"when_closing_with_no_tabs": "close_window",
	"use_system_window_tabs": true,
	"disable_ai": true,
	"ui_font_family": ".SystemUIFont",
	"ui_font_weight": 400.0,
	"autosave": {
		"after_delay": {
			"milliseconds": 1000,
		},
	},
	"agent_buffer_font_size": 12.0,
	"agent_ui_font_size": 16.0,
	"ui_font_size": 13.0,
	"buffer_line_height": "standard",
	"theme": {
		"mode": "system",
		"light": "Solarized Light",
		"dark": "Solarized Dark",
	},
	"buffer_font_size": 11.5,
	"buffer_font_family": "Pragmata Pro",
	"terminal": {
		"max_scroll_history_lines": 100000,
		"shell": null,
		"working_directory": null,
		"font_size": null,
		"font_family": "Pragmata Pro Mono",
		"font_features": null,
		"env": null,
		"blinking": null,
		"alternate_scroll": null,
		"option_as_meta": true,
		"copy_on_select": null,
	},
	"hard_tabs": true,
	"preferred_line_length": 120,
	"languages": {
		"XML": {
			"prettier": {
				"allowed": true,
				"plugins": ["@prettier/plugin-xml"],
				"bracketSameLine": true,
				"printWidth": 1000,
				"xmlWhitespaceSensitivity": "ignore",
			},
		},
	},
}
